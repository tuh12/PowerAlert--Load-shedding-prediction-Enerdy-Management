    <script>

        let gridChart = null;
        let updateInterval;

        const AREAS = {
            'SAVAR': 'Savar',
            'DHAKA': 'Dhaka City', 
            'GAZIPUR': 'Gazipur',
            'NARAYANGANJ': 'Narayanganj'
        };

        function initApp() {
            setTimeout(() => {
                document.getElementById('loadingScreen').classList.add('hidden');
                document.getElementById('mainApp').classList.remove('hidden');
                initGridChart();
                startLiveUpdates();
            }, 2000);
        }

        function initGridChart() {
            const ctx = document.getElementById('gridChart').getContext('2d');
            gridChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00', '24:00'],
                    datasets: [{
                        label: 'Net Power (MW)',
                        data: [-2246, -1000, -2296, -1800, -1200, -800, -500],
                        borderColor: '#EF4444',
                        backgroundColor: 'rgba(239, 68, 68, 0.1)',
                        tension: 0.4,
                        fill: true,
                        pointBackgroundColor: '#EF4444'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'top' } },
                    scales: {
                        y: { beginAtZero: false, grid: { color: 'rgba(0,0,0,0.1)' } }
                    }
                }
            });
        }

        function startLiveUpdates() {
            updateGridData();
            updateInterval = setInterval(updateGridData, 5000);
        }

        function updateGridData() {
            const generation = 11200 + Math.floor(Math.random() * 500);
            const demand = 13500 + Math.floor(Math.random() * 300);
            const deficit = Math.max(0, demand - generation);
            
            document.getElementById('generationValue').textContent = generation.toLocaleString();
            document.getElementById('demandValue').textContent = demand.toLocaleString();
            document.getElementById('deficitValue').textContent = deficit.toLocaleString();
            document.getElementById('timestamp').textContent = new Date().toLocaleTimeString('en-BD');
  
            if (gridChart) {
                gridChart.data.datasets[0].data = [
                    generation - demand, -1000, -2296, -1800, -1200, -800, -500
                ];
                gridChart.update('none');
            }
        }

        function showView(view) {
            // Hide all views
            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('scheduleView').classList.add('hidden');
            
            document.getElementById('dashboardTab').classList.remove('bg-white/20');
            document.getElementById('scheduleTab').classList.remove('bg-white/20');
            
            if (view === 'dashboard') {
                document.getElementById('dashboardView').classList.remove('hidden');
                document.getElementById('dashboardTab').classList.add('bg-white/20');
            } else if (view === 'schedule') {
                document.getElementById('scheduleView').classList.remove('hidden');
                document.getElementById('scheduleTab').classList.add('bg-white/20');
            }
        }

        function updateAreaSchedule() {
            const areaCode = document.getElementById('areaSelect').value;
            document.getElementById('scheduleTitle').textContent = `📅 ${AREAS[areaCode]} Schedule`;
        }

        function showAlerts() {
            alert('🔔 Load Shedding Alert!\n\nPower will be cut in your area at 6:00 PM\n\n⏰ Charge your phone now!');
        }
        function updateChart() {
            updateGridData();
        }

        window.onload = initApp;
    </script>
</body>
</html>
